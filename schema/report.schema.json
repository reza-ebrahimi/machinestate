{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/reza-ebrahimi/machinestate/report.schema.json",
  "title": "MachineState Report",
  "description": "System state report generated by machinestate",
  "type": "object",
  "required": [
    "timestamp",
    "hostname",
    "os",
    "system",
    "disk",
    "network",
    "packages",
    "services",
    "security",
    "hardware",
    "issues"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "description": "RFC3339 formatted timestamp"
    },
    "hostname": {
      "type": "string",
      "minLength": 1
    },
    "os": {
      "$ref": "#/$defs/OSInfo"
    },
    "system": {
      "$ref": "#/$defs/SystemInfo"
    },
    "disk": {
      "$ref": "#/$defs/DiskInfo"
    },
    "network": {
      "$ref": "#/$defs/NetworkInfo"
    },
    "packages": {
      "$ref": "#/$defs/PackageInfo"
    },
    "services": {
      "$ref": "#/$defs/ServiceInfo"
    },
    "security": {
      "$ref": "#/$defs/SecurityInfo"
    },
    "hardware": {
      "$ref": "#/$defs/HardwareInfo"
    },
    "docker": {
      "oneOf": [{ "$ref": "#/$defs/DockerInfo" }, { "type": "null" }]
    },
    "snaps": {
      "oneOf": [{ "$ref": "#/$defs/SnapInfo" }, { "type": "null" }]
    },
    "gpu": {
      "oneOf": [{ "$ref": "#/$defs/GPUInfo" }, { "type": "null" }]
    },
    "logs": {
      "oneOf": [{ "$ref": "#/$defs/LogInfo" }, { "type": "null" }]
    },
    "issues": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Issue"
      }
    }
  },
  "$defs": {
    "OSInfo": {
      "type": "object",
      "required": ["name", "version", "kernel", "architecture"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "kernel": { "type": "string" },
        "architecture": { "type": "string" }
      }
    },
    "SystemInfo": {
      "type": "object",
      "required": [
        "uptime",
        "uptime_human",
        "timezone",
        "reboot_required",
        "load_avg_1",
        "load_avg_5",
        "load_avg_15",
        "cpu_cores",
        "cpu_usage",
        "memory_total",
        "memory_used",
        "memory_free",
        "memory_percent",
        "swap_total",
        "swap_used",
        "swap_percent"
      ],
      "properties": {
        "uptime": { "type": "integer", "minimum": 0 },
        "uptime_human": { "type": "string" },
        "timezone": { "type": "string" },
        "reboot_required": { "type": "boolean" },
        "load_avg_1": { "type": "number", "minimum": 0 },
        "load_avg_5": { "type": "number", "minimum": 0 },
        "load_avg_15": { "type": "number", "minimum": 0 },
        "cpu_cores": { "type": "integer", "minimum": 1 },
        "cpu_usage": { "type": "number", "minimum": 0, "maximum": 100 },
        "memory_total": { "type": "integer", "minimum": 0 },
        "memory_used": { "type": "integer", "minimum": 0 },
        "memory_free": { "type": "integer", "minimum": 0 },
        "memory_percent": { "type": "number", "minimum": 0, "maximum": 100 },
        "swap_total": { "type": "integer", "minimum": 0 },
        "swap_used": { "type": "integer", "minimum": 0 },
        "swap_percent": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "DiskInfo": {
      "type": "object",
      "required": ["filesystems"],
      "properties": {
        "filesystems": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Filesystem"
          }
        }
      }
    },
    "Filesystem": {
      "type": "object",
      "required": [
        "device",
        "mount_point",
        "fs_type",
        "total",
        "used",
        "free",
        "used_percent",
        "inodes_total",
        "inodes_used",
        "inodes_free",
        "inodes_percent"
      ],
      "properties": {
        "device": { "type": "string" },
        "mount_point": { "type": "string" },
        "fs_type": { "type": "string" },
        "total": { "type": "integer", "minimum": 0 },
        "used": { "type": "integer", "minimum": 0 },
        "free": { "type": "integer", "minimum": 0 },
        "used_percent": { "type": "number", "minimum": 0, "maximum": 100 },
        "inodes_total": { "type": "integer", "minimum": 0 },
        "inodes_used": { "type": "integer", "minimum": 0 },
        "inodes_free": { "type": "integer", "minimum": 0 },
        "inodes_percent": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "NetworkInfo": {
      "type": "object",
      "required": ["interfaces", "listen_ports", "connectivity"],
      "properties": {
        "interfaces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Interface"
          }
        },
        "listen_ports": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ListenPort"
          }
        },
        "connectivity": { "type": "boolean" },
        "public_ip": { "type": "string" }
      }
    },
    "Interface": {
      "type": "object",
      "required": ["name", "state", "mac", "ips", "rx_bytes", "tx_bytes"],
      "properties": {
        "name": { "type": "string" },
        "state": { "type": "string", "enum": ["UP", "DOWN", "UNKNOWN"] },
        "mac": { "type": "string" },
        "ips": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rx_bytes": { "type": "integer", "minimum": 0 },
        "tx_bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "ListenPort": {
      "type": "object",
      "required": ["protocol", "address", "port"],
      "properties": {
        "protocol": { "type": "string", "enum": ["TCP", "UDP"] },
        "address": { "type": "string" },
        "port": { "type": "integer", "minimum": 0, "maximum": 65535 },
        "process": { "type": "string" },
        "pid": { "type": "integer", "minimum": 0 }
      }
    },
    "PackageInfo": {
      "type": "object",
      "required": ["updates_available", "security_updates", "broken_packages"],
      "properties": {
        "updates_available": { "type": "integer", "minimum": 0 },
        "updates_list": {
          "type": "array",
          "items": { "type": "string" }
        },
        "security_updates": { "type": "integer", "minimum": 0 },
        "broken_packages": { "type": "integer", "minimum": 0 },
        "held_packages": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "ServiceInfo": {
      "type": "object",
      "required": ["failed_units", "zombie_count", "top_cpu", "top_memory"],
      "properties": {
        "failed_units": {
          "type": "array",
          "items": { "type": "string" }
        },
        "zombie_count": { "type": "integer", "minimum": 0 },
        "top_cpu": {
          "type": "array",
          "items": { "$ref": "#/$defs/ProcessInfo" }
        },
        "top_memory": {
          "type": "array",
          "items": { "$ref": "#/$defs/ProcessInfo" }
        }
      }
    },
    "ProcessInfo": {
      "type": "object",
      "required": ["pid", "name", "cpu", "memory", "user"],
      "properties": {
        "pid": { "type": "integer", "minimum": 0 },
        "name": { "type": "string" },
        "cpu": { "type": "number", "minimum": 0 },
        "memory": { "type": "number", "minimum": 0 },
        "user": { "type": "string" }
      }
    },
    "SecurityInfo": {
      "type": "object",
      "required": [
        "firewall_active",
        "firewall_status",
        "failed_logins_24h",
        "open_ports",
        "ssh_enabled"
      ],
      "properties": {
        "firewall_active": { "type": "boolean" },
        "firewall_status": { "type": "string" },
        "failed_logins_24h": { "type": "integer", "minimum": 0 },
        "open_ports": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ssh_enabled": { "type": "boolean" }
      }
    },
    "HardwareInfo": {
      "type": "object",
      "required": [],
      "properties": {
        "battery": {
          "oneOf": [{ "$ref": "#/$defs/BatteryInfo" }, { "type": "null" }]
        },
        "temperatures": {
          "oneOf": [
            {
              "type": "array",
              "items": { "$ref": "#/$defs/TemperatureInfo" }
            },
            { "type": "null" }
          ]
        },
        "crash_reports": {
          "oneOf": [
            {
              "type": "array",
              "items": { "type": "string" }
            },
            { "type": "null" }
          ]
        }
      }
    },
    "BatteryInfo": {
      "type": "object",
      "required": [
        "present",
        "status",
        "capacity",
        "health",
        "cycle_count",
        "design_capacity",
        "full_capacity"
      ],
      "properties": {
        "present": { "type": "boolean" },
        "status": { "type": "string" },
        "capacity": { "type": "number", "minimum": 0 },
        "health": { "type": "number", "minimum": 0 },
        "cycle_count": { "type": "integer", "minimum": 0 },
        "design_capacity": { "type": "number", "minimum": 0 },
        "full_capacity": { "type": "number", "minimum": 0 }
      }
    },
    "TemperatureInfo": {
      "type": "object",
      "required": ["label", "current"],
      "properties": {
        "label": { "type": "string" },
        "current": { "type": "number" },
        "high": { "type": "number" },
        "critical": { "type": "number" }
      }
    },
    "DockerInfo": {
      "type": "object",
      "required": [
        "available",
        "daemon_running",
        "running_count",
        "stopped_count",
        "image_count",
        "total_image_size",
        "dangling_images_size"
      ],
      "properties": {
        "available": { "type": "boolean" },
        "daemon_running": { "type": "boolean" },
        "containers": {
          "oneOf": [
            {
              "type": "array",
              "items": { "$ref": "#/$defs/ContainerInfo" }
            },
            { "type": "null" }
          ]
        },
        "running_count": { "type": "integer", "minimum": 0 },
        "stopped_count": { "type": "integer", "minimum": 0 },
        "image_count": { "type": "integer", "minimum": 0 },
        "total_image_size": { "type": "integer", "minimum": 0 },
        "dangling_images_size": { "type": "integer", "minimum": 0 }
      }
    },
    "ContainerInfo": {
      "type": "object",
      "required": ["name", "image", "status", "state", "created"],
      "properties": {
        "name": { "type": "string" },
        "image": { "type": "string" },
        "status": { "type": "string" },
        "state": { "type": "string" },
        "created": { "type": "string" },
        "cpu_percent": { "type": "number", "minimum": 0 },
        "memory_percent": { "type": "number", "minimum": 0 }
      }
    },
    "SnapInfo": {
      "type": "object",
      "required": ["available", "total_disk_usage", "pending_refreshes"],
      "properties": {
        "available": { "type": "boolean" },
        "snaps": {
          "oneOf": [
            {
              "type": "array",
              "items": { "$ref": "#/$defs/SnapPackage" }
            },
            { "type": "null" }
          ]
        },
        "total_disk_usage": { "type": "integer", "minimum": 0 },
        "pending_refreshes": { "type": "integer", "minimum": 0 }
      }
    },
    "SnapPackage": {
      "type": "object",
      "required": ["name", "version", "revision", "publisher", "disk_usage"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "revision": { "type": "string" },
        "publisher": { "type": "string" },
        "disk_usage": { "type": "integer", "minimum": 0 }
      }
    },
    "GPUInfo": {
      "type": "object",
      "required": ["available"],
      "properties": {
        "available": { "type": "boolean" },
        "gpus": {
          "oneOf": [
            {
              "type": "array",
              "items": { "$ref": "#/$defs/GPUDevice" }
            },
            { "type": "null" }
          ]
        }
      }
    },
    "GPUDevice": {
      "type": "object",
      "required": ["index", "name", "vendor"],
      "properties": {
        "index": { "type": "integer", "minimum": 0 },
        "name": { "type": "string" },
        "vendor": { "type": "string" },
        "temperature": { "type": "integer", "minimum": 0 },
        "utilization": { "type": "integer", "minimum": 0, "maximum": 100 },
        "memory_used": { "type": "integer", "minimum": 0 },
        "memory_total": { "type": "integer", "minimum": 0 },
        "power_draw": { "type": "number", "minimum": 0 }
      }
    },
    "LogInfo": {
      "type": "object",
      "required": ["available", "period", "stats"],
      "properties": {
        "available": { "type": "boolean" },
        "period": { "type": "string" },
        "stats": { "$ref": "#/$defs/LogStats" }
      }
    },
    "LogStats": {
      "type": "object",
      "required": [
        "error_count",
        "warning_count",
        "critical_count",
        "oom_events",
        "kernel_panics",
        "segfaults"
      ],
      "properties": {
        "error_count": { "type": "integer", "minimum": 0 },
        "warning_count": { "type": "integer", "minimum": 0 },
        "critical_count": { "type": "integer", "minimum": 0 },
        "oom_events": { "type": "integer", "minimum": 0 },
        "kernel_panics": { "type": "integer", "minimum": 0 },
        "segfaults": { "type": "integer", "minimum": 0 },
        "top_errors": {
          "oneOf": [
            {
              "type": "array",
              "items": { "$ref": "#/$defs/ErrorPattern" }
            },
            { "type": "null" }
          ]
        }
      }
    },
    "ErrorPattern": {
      "type": "object",
      "required": ["pattern", "count"],
      "properties": {
        "pattern": { "type": "string" },
        "count": { "type": "integer", "minimum": 1 }
      }
    },
    "Issue": {
      "type": "object",
      "required": ["severity", "category", "title", "description"],
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["critical", "warning", "info"]
        },
        "category": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "fix": { "type": "string" }
      }
    }
  }
}
