{
  "type": "object",
  "required": [
    "available",
    "total_disk_usage",
    "pending_refreshes"
  ],
  "properties": {
    "available": {
      "type": "boolean"
    },
    "snaps": {
      "oneOf": [
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SnapPackage"
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "total_disk_usage": {
      "type": "integer",
      "minimum": 0
    },
    "pending_refreshes": {
      "type": "integer",
      "minimum": 0
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
