{
  "type": "object",
  "required": [
    "available",
    "daemon_running",
    "running_count",
    "stopped_count",
    "image_count",
    "total_image_size",
    "dangling_images_size"
  ],
  "properties": {
    "available": {
      "type": "boolean"
    },
    "daemon_running": {
      "type": "boolean"
    },
    "containers": {
      "oneOf": [
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ContainerInfo"
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "running_count": {
      "type": "integer",
      "minimum": 0
    },
    "stopped_count": {
      "type": "integer",
      "minimum": 0
    },
    "image_count": {
      "type": "integer",
      "minimum": 0
    },
    "total_image_size": {
      "type": "integer",
      "minimum": 0
    },
    "dangling_images_size": {
      "type": "integer",
      "minimum": 0
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
