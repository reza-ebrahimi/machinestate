{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DiskInfo",
  "type": "object",
  "required": ["filesystems"],
  "properties": {
    "filesystems": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["device", "mount_point", "fs_type", "total", "used", "free", "used_percent", "inodes_total", "inodes_used", "inodes_free", "inodes_percent"],
        "properties": {
          "device": { "type": "string" },
          "mount_point": { "type": "string" },
          "fs_type": { "type": "string" },
          "total": { "type": "integer", "minimum": 0 },
          "used": { "type": "integer", "minimum": 0 },
          "free": { "type": "integer", "minimum": 0 },
          "used_percent": { "type": "number", "minimum": 0 },
          "inodes_total": { "type": "integer", "minimum": 0 },
          "inodes_used": { "type": "integer", "minimum": 0 },
          "inodes_free": { "type": "integer", "minimum": 0 },
          "inodes_percent": { "type": "number", "minimum": 0 }
        }
      }
    }
  }
}
