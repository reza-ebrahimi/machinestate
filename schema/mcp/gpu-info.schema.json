{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GPUInfo",
  "type": "object",
  "required": ["available"],
  "properties": {
    "available": { "type": "boolean" },
    "gpus": {
      "oneOf": [
        {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["index", "name", "vendor"],
            "properties": {
              "index": { "type": "integer", "minimum": 0 },
              "name": { "type": "string" },
              "vendor": { "type": "string" },
              "temperature": { "type": "integer", "minimum": 0 },
              "utilization": { "type": "integer", "minimum": 0 },
              "memory_used": { "type": "integer", "minimum": 0 },
              "memory_total": { "type": "integer", "minimum": 0 },
              "power_draw": { "type": "number", "minimum": 0 }
            }
          }
        },
        { "type": "null" }
      ]
    }
  }
}
